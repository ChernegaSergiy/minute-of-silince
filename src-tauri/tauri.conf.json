{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minute of Silence",
  "identifier": "ua.pp.khvylyna.MinuteOfSilence",
  "version": "0.10.3",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": ["audio/*", "Strings"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["uk-UA"]
      }
    },
    "linux": {
      "deb": {
        "depends": ["libasound2"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0RDI3REM0OERBQjFGMjIKUldRaUg2dU54SDNTWklYRWdhU2MzOW5xVDVtb0NPZlNibG1qYzIvbURCSE5HYVAvZHdBZ2svRkgK",
      "endpoints": [
        "https://github.com/ChernegaSergiy/minute-of-silence/releases/latest/download/latest.json"
      ]
    }
  }
}
