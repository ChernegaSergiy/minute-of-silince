{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minute of Silence",
  "identifier": "ua.pp.khvylyna.MinuteOfSilence",
  "version": "0.9.0",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Хвилина мовчання",
        "label": "main",
        "width": 640,
        "height": 520,
        "minWidth": 500,
        "minHeight": 400,
        "resizable": true,
        "decorations": true,
        "center": true,
        "skipTaskbar": true,
        "alwaysOnTop": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["audio/*", "Strings"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["uk-UA"]
      }
    },
    "linux": {
      "deb": {
        "depends": ["libasound2"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {}
}
